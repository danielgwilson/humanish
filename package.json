{
  "name": "mimetic-cli",
  "version": "0.12.9",
  "description": "Open-source-safe CLI for persona simulation, observer review, and public-safe feedback drafts.",
  "author": "Daniel G Wilson <daniel@danielgwilson.com>",
  "keywords": [
    "agent-harness",
    "cli",
    "persona-simulation",
    "ui-testing",
    "ux-research"
  ],
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mimetic": "./dist/cli.js"
  },
  "files": [
    "AGENTS.md",
    "dist",
    "docs/architecture",
    "docs/assets",
    "docs/contracts",
    "docs/goals/current.md",
    "docs/principles",
    "docs/product",
    "docs/ramp",
    "docs/release",
    "docs/roadmap",
    "skills",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node --eval \"import('node:fs').then(({ chmodSync }) => chmodSync('dist/cli.js', 0o755))\"",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "mimetic": "tsx src/cli.ts",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm build",
    "public-surface:scan": "node scripts/public-surface-scan.mjs",
    "release:check": "pnpm check && pnpm public-surface:scan && pnpm skill:check && npm pack --dry-run",
    "skill:check": "DISABLE_TELEMETRY=1 npx skills add . --list",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "mimetic:doctor": "pnpm mimetic -- doctor",
    "mimetic:run": "pnpm mimetic -- run --dry-run",
    "mimetic:watch": "pnpm mimetic -- watch",
    "mimetic:watch:ci": "pnpm mimetic -- watch --json --no-open",
    "mimetic:dogfood": "pnpm mimetic -- watch",
    "mimetic:verify": "pnpm mimetic -- verify",
    "mimetic:feedback": "pnpm mimetic -- feedback issue --repo danielgwilson/mimetic-cli",
    "mimetic:lab:list": "pnpm mimetic -- lab list",
    "mimetic:lab:oss": "pnpm mimetic -- lab run oss",
    "mimetic:lab:oss:ci": "pnpm mimetic -- lab run oss --dry-run --json --no-open",
    "mimetic:lab:oss:smoke": "pnpm mimetic -- lab run oss-smoke"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danielgwilson/mimetic-cli.git"
  },
  "bugs": {
    "url": "https://github.com/danielgwilson/mimetic-cli/issues"
  },
  "homepage": "https://github.com/danielgwilson/mimetic-cli#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "playwright-core": "^1.60.0",
    "pngjs": "^7.0.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@e2b/desktop": "^2.2.3"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@e2b/desktop": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@e2b/desktop": "^2.2.3",
    "@types/node": "^20.19.41",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
