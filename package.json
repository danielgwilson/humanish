{
  "name": "mimetic-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source-safe CLI for persona simulation, observer review, and public-safe feedback drafts.",
  "keywords": [
    "agent-harness",
    "cli",
    "persona-simulation",
    "ui-testing",
    "ux-research"
  ],
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.26.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mimetic": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node --eval \"import('node:fs').then(({ chmodSync }) => chmodSync('dist/cli.js', 0o755))\"",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "mimetic": "tsx src/cli.ts",
    "pack:dry-run": "pnpm build && npm pack --dry-run",
    "release:check": "pnpm check && npm pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "mimetic:doctor": "pnpm mimetic -- doctor",
    "mimetic:run": "pnpm mimetic -- run --dry-run",
    "mimetic:watch": "pnpm mimetic -- watch",
    "mimetic:watch:ci": "pnpm mimetic -- watch --json --no-open",
    "mimetic:dogfood": "pnpm mimetic -- watch",
    "mimetic:verify": "pnpm mimetic -- verify",
    "mimetic:feedback": "pnpm mimetic -- feedback issue --repo danielgwilson/mimetic-cli",
    "mimetic:lab:oss": "pnpm mimetic -- lab oss"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danielgwilson/mimetic-cli.git"
  },
  "bugs": {
    "url": "https://github.com/danielgwilson/mimetic-cli/issues"
  },
  "homepage": "https://github.com/danielgwilson/mimetic-cli#readme",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
